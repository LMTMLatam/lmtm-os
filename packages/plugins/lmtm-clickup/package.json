{
  "name": "@paperclipai/lmtm-clickup",
  "version": "0.1.0",
  "description": "ClickUp tools for LMTM-OS agents — list/read/write tasks, comments, and search across the agency's ClickUp workspace.",
  "type": "module",
  "private": true,
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "production": "./dist/index.js",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "paperclipPlugin": {
    "manifest": "./dist/manifest.js",
    "worker": "./dist/worker.js"
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@paperclipai/plugin-sdk": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "typescript": "^5.7.3"
  }
}
