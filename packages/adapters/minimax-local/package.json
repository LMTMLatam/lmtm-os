{
  "name": "@paperclipai/adapter-minimax-local",
  "version": "0.1.0",
  "license": "MIT",
  "description": "LMTM-OS: MiniMax M3 chat-completion adapter as a first-class Paperclip agent runtime. Supports session resume, skill materialization, JWT auth, and per-agent API key overrides.",
