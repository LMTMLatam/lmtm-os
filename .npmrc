# LMTM-OS: pnpm config tuned for memory-constrained CI builds (Render Starter = 512MB).
# node-linker=hoisted: flat node_modules, no symlink graph → MUCH less memory in
#   pnpm install. Downside: phantom-dependency risk; we accept it because the
#   server's build is type-checked and the workspace is small (≈20 internal
#   packages). For an external-facing monorepo, prefer the default isolated
#   linker.
# auto-install-peers=false: don't eagerly resolve peer deps that aren't declared
#   in the dependent's package.json. Saves a lot of resolution work.
# strict-peer-dependencies=false: same idea, be lenient about peer warnings.
# package-import-method=hardlink: hardlink tarballs into node_modules instead of
#   copying. Significantly less I/O and slightly less memory.
# node-options: limit V8 heap to 350MB so pnpm/Node can never balloon past
#   Render's 512MB cgroup limit (leaving headroom for OS + Docker).
auto-install-peers=false
strict-peer-dependencies=false
node-linker=hoisted
package-import-method=hardlink
node-options=--max-old-space-size=350
