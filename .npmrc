# LMTM-OS: pnpm config tuned for memory-constrained CI builds (Render Starter = 512MB).
# These settings are intentionally minimal — we accept pnpm's defaults
# for everything else, which are well-tuned for large monorepos.
#
# --ignore-scripts is the biggest memory saver (postinstall scripts can
# spawn child Node processes that double peak memory).
# --auto-install-peers=false: don't eagerly resolve peer deps that aren't
# declared in the dependent's package.json. Saves a lot of resolution
# work in a 200+-package monorepo.
auto-install-peers=false
strict-peer-dependencies=false
