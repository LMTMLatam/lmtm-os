{
  "useChrome": true,
  "executablePath": "/usr/bin/google-chrome",
  "qrTimeout": 300,
  "authTimeout": 300,
  "cacheEnabled": false,
  "autoRefresh": true,
  "killByLogout": false,
  "useSessionIdInPath": false,
  "headless": true,
  "disableSpins": true,
  "logDebugInfoAsObject": false,
  "skipBrowserCheck": true,
  "useChromeHeadless": true,
  "chromiumArgs": [
    "--no-sandbox",
    "--disable-setuid-sandbox",
    "--disable-dev-shm-usage",
    "--disable-gpu",
    "--no-zygote",
    "--disable-background-networking",
    "--disable-default-apps",
    "--disable-extensions",
    "--disable-sync",
    "--metrics-recording-only",
    "--mute-audio",
    "--no-first-run",
    "--safebrowsing-disable-auto-update",
    "--disable-features=TranslateUI,BlinkGenPropertyTrees,AudioServiceOutOfProcess",
    "--disable-blink-features=AutomationControlled"
  ]
}
