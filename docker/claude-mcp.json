{
  "mcpServers": {
    "paperclip": {
      "command": "/usr/local/bin/node",
      "args": ["--conditions=production", "/app/packages/mcp-server/dist/stdio.js"],
      "env": {
        "PATH": "/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin",
        "PAPERCLIP_API_URL": "${PAPERCLIP_API_URL}",
        "PAPERCLIP_API_KEY": "${PAPERCLIP_API_KEY}",
        "PAPERCLIP_AGENT_ID": "${PAPERCLIP_AGENT_ID}",
        "PAPERCLIP_COMPANY_ID": "${PAPERCLIP_COMPANY_ID}",
        "PAPERCLIP_RUN_ID": "${PAPERCLIP_RUN_ID}",
        "PAPERCLIP_MCP_TOOLS": "${PAPERCLIP_MCP_TOOLS}"
      }
    },
    "make": {
      "type": "http",
      "url": "https://us2.make.com/mcp/u/9da30dee-be95-4797-a36a-d955ab765b75/stateless"
    },
    "trends": {
      "type": "http",
      "url": "https://api.trendsmcp.ai/mcp",
      "headers": {
        "Authorization": "Bearer ${TRENDS_MCP_API_KEY}"
      }
    },
    "google": {
      "command": "/usr/local/bin/node",
      "args": ["--conditions=production", "/app/packages/mcp-servers/google/dist/stdio.js"],
      "env": {
        "PATH": "/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin",
        "GOOGLE_OAUTH_CLIENT_ID": "${GOOGLE_OAUTH_CLIENT_ID}",
        "GOOGLE_OAUTH_CLIENT_SECRET": "${GOOGLE_OAUTH_CLIENT_SECRET}",
        "GOOGLE_OAUTH_REFRESH_TOKEN": "${GOOGLE_OAUTH_REFRESH_TOKEN}"
      }
    },
    "clickup": {
      "command": "/usr/local/bin/node",
      "args": ["--conditions=production", "/app/packages/mcp-servers/clickup/dist/stdio.js"],
      "env": {
        "PATH": "/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin",
        "CLICKUP_API_TOKEN": "${CLICKUP_API_TOKEN}"
      }
    }
  }
}
